<?xml version="1.0" encoding="utf-8"?>
<!-- HTTP「请求」Tab：同响应页，避免 NestedScrollView 占满屏后在正文下缘出现透明「空条」。 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sunny_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/detail_section_request_info_label"
                style="@style/Widget.SunnyNet.DetailSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_section_request_info"
                tools:ignore="TextContrastCheck" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/detail_request_info_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/sunny_surface"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="4"
                tools:listitem="@layout/item_detail_overview_row" />

            <!-- 协议头列表默认收起，点按标题行展开 -->
            <LinearLayout
                android:id="@+id/detail_request_headers_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/sunny_surface_variant"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="8dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/detail_section_request_headers_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/detail_section_request_headers"
                    android:textAppearance="@style/TextAppearance.SunnyNet.DetailSectionLabel"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/detail_request_headers_expand_icon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/detail_headers_content_desc_collapsed"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_expand_more"
                    app:tint="@color/sunny_on_surface_variant"
                    tools:ignore="ImageContrastCheck" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/detail_request_headers_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/sunny_surface"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:visibility="gone"
                tools:itemCount="3"
                tools:listitem="@layout/item_detail_overview_row"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/detail_section_request_body_label"
                style="@style/Widget.SunnyNet.DetailSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_section_request_body" />

            <LinearLayout
                android:id="@+id/detail_request_body_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/sunny_surface"
                android:orientation="vertical">

                <include layout="@layout/include_detail_http_body_block" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
