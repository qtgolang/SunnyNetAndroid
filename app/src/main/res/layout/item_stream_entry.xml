<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 展示序号（当前列表从上到下 1…n，非 SDK MessageId） -->
            <TextView
                android:id="@+id/stream_seq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/sunny_on_surface_variant"
                tools:text="#1" />

            <TextView
                android:id="@+id/stream_direction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_protocol_http"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textStyle="bold"
                tools:text="发送（共128字节）" />

            <TextView
                android:id="@+id/stream_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="end"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/sunny_on_surface_variant"
                tools:text="12:00:00.123" />
        </LinearLayout>

        <TextView
            android:id="@+id/stream_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/sunny_on_surface"
            tools:text="07 0A 10 01 …" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
