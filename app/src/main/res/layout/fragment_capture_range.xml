<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:clipToPadding="false"
    android:padding="@dimen/card_margin">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <TextView
                style="@style/Widget.SunnyNet.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/capture_range_title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/capture_range_desc"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/sunny_on_surface_variant" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/capture_range_http"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/capture_range_http" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/capture_range_websocket"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/capture_range_websocket" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/capture_range_tcp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/capture_range_tcp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/capture_range_udp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/capture_range_udp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>
